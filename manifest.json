{
  "manifest_version": 3,
  "name": "BOSS海投助手",
  "version": "0.1.1",
  "description": "在 BOSS 直聘页面注入右上角悬浮助手小窗。",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.zhipin.com/*",
    "https://zhipin.com/*",
    "https://api.deepseek.com/*",
    "https://ark.cn-beijing.volces.com/*",
    "https://api.hunyuan.cloud.tencent.com/*",
    "https://*.tencentcloudapi.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.zhipin.com/*",
        "https://zhipin.com/*"
      ],
      "js": [
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "BOSS海投助手"
  }
}